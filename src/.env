# .env —— docker-compose 变量插值文件
# compose 文件中用 ${变量名} 引用，同时也作为容器运行时 env 的来源
# 修改此文件后重启容器（docker compose up -d）即可生效

# ── 镜像（与宿主机已下载版本对齐）──
LLAMAFACTORY_IMAGE=hiyouga/llamafactory:0.9.4
VERL_IMAGE=verlai/verl:vllm012.latest
VLLM_IMAGE=vllm/vllm-openai:latest

# ── GPU（8 卡机器只用 0-3）──
CUDA_VISIBLE_DEVICES=0,1,2,3
GPU_IDS=0,1,2,3

# ── NCCL ──
NCCL_DEBUG=WARN
NCCL_IB_DISABLE=1
NCCL_P2P_DISABLE=0
CUDA_DEVICE_MAX_CONNECTIONS=1

# ── Python / HuggingFace ──
PYTHONPATH=/workspace
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
