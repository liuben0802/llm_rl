# .env —— 宿主机环境变量，docker-compose 自动加载
# 按实际情况修改后直接 docker-compose up 即可

# ── GPU 选择（8 卡机器只用 0-3）──
# device_ids 决定哪些物理卡被映射进容器
# 容器内映射后编号自动重排为 0-3，训练脚本无需感知宿主机卡号
# 若要换成另外四张卡（4-7），把下面两处都改掉：
#   1. docker-compose.yml → device_ids: ["4","5","6","7"]
#   2. 本文件 CUDA_VISIBLE_DEVICES=4,5,6,7（供宿主机脚本 nvidia-smi 监控用）
CUDA_VISIBLE_DEVICES=0,1,2,3

# ── 镜像版本（固定版本号，避免 latest 不稳定）──
LLAMAFACTORY_IMAGE=hiyouga/llamafactory:latest
VERL_IMAGE=verlai/verl:vemlp-th2.4.0-cu124-vllm0.6.3-ray2.10-te2.0-v0.3.0.post1

# ── 模型路径（HuggingFace Hub 缓存目录中的路径）──
QWEN3_14B_PATH=/workspace/.cache/huggingface/hub/Qwen3-14B
QWEN72B_PATH=/workspace/.cache/huggingface/hub/Qwen2.5-72B-Instruct

# ── 训练配置 ──
GPU_COUNT=4
SFT_EPOCHS=1
RM_EPOCHS=3
GRPO_EPOCHS=2
